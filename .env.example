# ======================================
# TechEcosystem Backend Environment Config
# ======================================

# ===== REQUIRED: JWT AUTHENTICATION =====
# Generate with: openssl rand -base64 32
# This encrypts user login tokens
JWT_SECRET=your-strong-secret-key-min-32-characters-long

# ===== REQUIRED: AWS CONFIGURATION =====
# Get from: AWS Console > IAM > Users > Security Credentials
AWS_REGION=us-east-1

# Profile name from: aws configure
# Default is 'default' - change if you have multiple profiles
AWS_PROFILE=default

# ===== REQUIRED: SERVERLESS CONFIGURATION =====
# Deployment stage: dev, staging, or prod
STAGE=dev
REGION=us-east-1

# ===== OPTIONAL: S3 BUCKET NAMES =====
# Create these in AWS S3 Console or with:
# aws s3 mb s3://techeco-api-videos-dev --region us-east-1
# aws s3 mb s3://techeco-api-resumes-dev --region us-east-1
VIDEOS_BUCKET=techeco-api-videos-dev
RESUMES_BUCKET=techeco-api-resumes-dev

# ===== OPTIONAL: AWS COGNITO (if using instead of JWT) =====
# Get from: AWS Cognito Console > User Pools > Your Pool
# COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# COGNITO_DOMAIN=your-app.auth.us-east-1.amazoncognito.com

# ===== OPTIONAL: SLACK NOTIFICATIONS =====
# For deployment status notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ===== OPTIONAL: EMAIL NOTIFICATIONS =====
# For user notifications (requires SES setup)
# AWS_SES_REGION=us-east-1
# SENDER_EMAIL=noreply@techeco.com

# ===== OPTIONAL: MONITORING & LOGGING =====
# CloudWatch logging level
# LOG_LEVEL=info

# ===== OPTIONAL: CUSTOM DOMAIN =====
# If using custom domain instead of default API Gateway URL
# CUSTOM_DOMAIN=api.techeco.com

# ===== OPTIONAL: RATE LIMITING =====
# Request rate limits (requests per second)
# RATE_LIMIT=100

# ===== OPTIONAL: DATABASE BACKUP =====
# S3 bucket for DynamoDB backups
# BACKUP_BUCKET=techeco-backups

